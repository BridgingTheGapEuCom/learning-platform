{
  "compilerOptions": {
    "target": "es2019",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@btg/shared-types": ["./index.ts"],
    },
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
